#!/bin/bash
# Restore test TeamSystem via restic — generated by Ansible

set -uo pipefail

source /etc/restic/restic.env

LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"
HOSTNAME="{{ hostname }}"
RESTORE_DIR="/tmp/restic-restore-test-$$"
RESTORE_STATUS="ok"
CHECKSUM_OK=1
ERROR_MSG=""
DURATION_S=0

cleanup() {
    rm -rf "$RESTORE_DIR"
}
trap cleanup EXIT

START_TIME=$(date +%s)

# Get latest snapshot_id from Master
API_KEY=$(echo -n "{{ master_secret }}$VPS_ID" | sha256sum | cut -d' ' -f1)

SNAPSHOT_ID=$(python3 -c "
import urllib.request, json, os
req = urllib.request.Request(
    os.environ['MASTER_URL'] + '/api/v1/servers/' + os.environ['VPS_ID'] + '/latest-snapshot',
    headers={'X-Api-Key': '$API_KEY'}
)
try:
    resp = urllib.request.urlopen(req, timeout=30)
    data = json.loads(resp.read())
    print(data.get('snapshot_id', ''))
except Exception as e:
    print('', end='')
" 2>/dev/null)

if [ -z "$SNAPSHOT_ID" ]; then
    RESTORE_STATUS="failed"
    ERROR_MSG="Nessun snapshot disponibile"
else
    # File campione: most recently modified file in first backup folder
    read -ra BACKUP_ARRAY <<< "$BACKUP_FOLDERS"
    FIRST_FOLDER="${BACKUP_ARRAY[0]}"

    SAMPLE_FILE=$(find "$FIRST_FOLDER" -type f -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)

    if [ -z "$SAMPLE_FILE" ]; then
        RESTORE_STATUS="failed"
        ERROR_MSG="Nessun file trovato in $FIRST_FOLDER"
    else
        ORIG_CHECKSUM=$(sha256sum "$SAMPLE_FILE" | cut -d' ' -f1)
        mkdir -p "$RESTORE_DIR"
        RELATIVE_PATH="${SAMPLE_FILE#/}"

        restic restore "$SNAPSHOT_ID" --target "$RESTORE_DIR" --include "$SAMPLE_FILE" --quiet 2>&1 || {
            RESTORE_STATUS="failed"
            ERROR_MSG="restic restore fallito"
        }

        if [ "$RESTORE_STATUS" = "ok" ]; then
            RESTORED_FILE="$RESTORE_DIR/$RELATIVE_PATH"
            if [ -f "$RESTORED_FILE" ]; then
                RESTORED_CHECKSUM=$(sha256sum "$RESTORED_FILE" | cut -d' ' -f1)
                if [ "$ORIG_CHECKSUM" != "$RESTORED_CHECKSUM" ]; then
                    CHECKSUM_OK=0
                    RESTORE_STATUS="failed"
                    ERROR_MSG="Checksum mismatch"
                fi
            else
                RESTORE_STATUS="failed"
                CHECKSUM_OK=0
                ERROR_MSG="File ripristinato non trovato: $RESTORED_FILE"
            fi
        fi
    fi
fi

END_TIME=$(date +%s)
DURATION_S=$((END_TIME - START_TIME))

# Report to Master
python3 -c "
import urllib.request, json, os
payload = {
    'vps_id': os.environ['VPS_ID'],
    'status': '$RESTORE_STATUS',
    'checksum_ok': $CHECKSUM_OK,
    'duration_s': $DURATION_S,
    'error_msg': '''$ERROR_MSG'''.strip()[:500]
}
data = json.dumps(payload).encode()
req = urllib.request.Request(
    os.environ['MASTER_URL'] + '/api/v1/restore/report',
    data=data,
    headers={'Content-Type': 'application/json', 'X-Api-Key': '$API_KEY'}
)
try:
    urllib.request.urlopen(req, timeout=30)
except Exception as e:
    import sys; print(f'Errore: {e}', file=sys.stderr)
"

echo "$LOG_PREFIX Restore test: status=$RESTORE_STATUS checksum_ok=$CHECKSUM_OK"
