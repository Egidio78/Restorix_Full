#!/bin/bash
# Backup TeamSystem via restic — generated by Ansible

set -uo pipefail

source /etc/restic/restic.env

LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"
HOSTNAME="{{ hostname }}"

echo "$LOG_PREFIX Avvio backup $VPS_ID"

# Fetch updated folders from Master (may have been edited from web UI)
export _MASTER_SECRET="{{ master_secret }}"
_FETCH_RESULT=$(python3 - << 'PYEOF'
import urllib.request, json, os, hashlib
vps_id = os.environ.get('VPS_ID', '')
master_url = os.environ.get('MASTER_URL', '')
secret = os.environ.get('_MASTER_SECRET', '')
if not (vps_id and master_url and secret):
    exit(0)
api_key = hashlib.sha256((secret + vps_id).encode()).hexdigest()
req = urllib.request.Request(
    master_url + '/api/v1/servers/' + vps_id + '/config',
    headers={'X-Api-Key': api_key}
)
try:
    resp = urllib.request.urlopen(req, timeout=10)
    data = json.loads(resp.read())
    folders = data.get('folders', [])
    if folders:
        print(' '.join(folders))
except Exception:
    pass
PYEOF
)
if [ -n "$_FETCH_RESULT" ]; then
    BACKUP_FOLDERS="$_FETCH_RESULT"
    echo "$LOG_PREFIX Cartelle aggiornate dal Master: $BACKUP_FOLDERS"
else
    echo "$LOG_PREFIX Cartelle dalla config locale: $BACKUP_FOLDERS"
fi
unset _MASTER_SECRET

# Stop TeamSystem
STOP_TIME=$(date +%s)
systemctl stop "$TEAMSYSTEM_SERVICE" 2>/dev/null || true
echo "$LOG_PREFIX TeamSystem fermato"

# Run backup
START_TIME=$(date +%s)
BACKUP_STATUS="ok"
SNAPSHOT_ID=""
ERROR_MSG=""

read -ra BACKUP_ARRAY <<< "$BACKUP_FOLDERS"

RESTIC_OUT=$(restic backup "${BACKUP_ARRAY[@]}" \
    --host "$HOSTNAME" \
    --json \
    --quiet 2>&1) || { BACKUP_STATUS="failed"; ERROR_MSG="$RESTIC_OUT"; }

if [ "$BACKUP_STATUS" = "ok" ]; then
    SNAPSHOT_ID=$(echo "$RESTIC_OUT" | python3 -c "import sys,json; data=[json.loads(l) for l in sys.stdin if l.strip()]; snap=[d for d in data if d.get('message_type')=='summary']; print(snap[-1].get('snapshot_id','') if snap else '')" 2>/dev/null || echo "")
    restic forget --keep-daily "$RESTIC_KEEP_DAILY" --keep-weekly "$RESTIC_KEEP_WEEKLY" --prune --host "$HOSTNAME" --quiet 2>/dev/null || true
fi

# Restart TeamSystem
systemctl start "$TEAMSYSTEM_SERVICE" 2>/dev/null || true
END_TIME=$(date +%s)
DOWNTIME_S=$((START_TIME - STOP_TIME))
DURATION_S=$((END_TIME - START_TIME))

# Disk usage
DISK_FREE_PCT=$(df --output=pcent / | tail -1 | tr -d '% ' | awk '{print 100-$1}' 2>/dev/null || echo "0")

# Size in GB
SIZE_GB=$(restic stats --json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print('%.2f' % (d.get('total_size',0)/1073741824))" 2>/dev/null || echo "0")

# Compute API key
API_KEY=$(echo -n "{{ master_secret }}$VPS_ID" | sha256sum | cut -d' ' -f1)

# Report to Master
FOLDERS_JSON=$(python3 -c "import json,os; print(json.dumps(os.environ.get('BACKUP_FOLDERS','').split()))" 2>/dev/null || echo '[]')

python3 -c "
import urllib.request, json, os, sys
payload = {
    'vps_id': os.environ['VPS_ID'],
    'status': '$BACKUP_STATUS',
    'snapshot_id': '$SNAPSHOT_ID',
    'size_gb': float('$SIZE_GB' or 0),
    'duration_s': $DURATION_S,
    'downtime_s': $DOWNTIME_S,
    'error_msg': '''$ERROR_MSG'''.strip()[:500],
    'disk_free_pct': float('$DISK_FREE_PCT' or 0),
    'folders': json.loads('''$FOLDERS_JSON''')
}
data = json.dumps(payload).encode()
req = urllib.request.Request(
    os.environ['MASTER_URL'] + '/api/v1/backup/report',
    data=data,
    headers={'Content-Type': 'application/json', 'X-Api-Key': '$API_KEY'}
)
try:
    urllib.request.urlopen(req, timeout=30)
    print('Report inviato al Master.')
except Exception as e:
    print(f'Errore invio report: {e}', file=sys.stderr)
"

echo "$LOG_PREFIX Backup completato: status=$BACKUP_STATUS, duration=${DURATION_S}s"
